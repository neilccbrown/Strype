{
    "name": "strype-editor",
    "version": "2.0.1",
    "private": true,
    "scripts": {
        "serve:microbit": "cross-env vite --mode microbit --port 8081",
        "serve:python": "npm run compile-service-worker && vite --mode standard --port 8081",
        "serve:python:dist:playwright": "rimraf temp-scripts/playwright-server && npm run build:python && mkdirp temp-scripts/playwright-server/editor/ && mv dist/* temp-scripts/playwright-server/editor/ && npx serve -l 8081 temp-scripts/playwright-server",
        "build:microbit": "cross-env vite build --mode microbit",
        "build:python": "npm run compile-service-worker && cross-env vite build --mode standard",
        "build:github-pages": "cross-env VITE_GITHUB_PAGE=true vite build --mode standard",
        "compile-service-worker": "npx node scripts/build-service-worker.mjs",
        "lint:check": "eslint . --ext .js,.vue --max-warnings 0",
        "library:make-ac-json": "cd scripts && npm install && npx tsc && (node -e \"console.log('library_arg = \\'' + process.env.LIBRARY + '\\';')\" && npx esbuild --loader:.py=text --alias:pysrc=../pysrc --bundle compiled/scripts/process-pyodide-api.js) | npx browser-run -s ../public > ../autocomplete.json",
        "preprocess:update-microbit-api": "python3.9 scripts/process-microbit-api.py > src/autocompletion/microbit-api.json",
        "preprocess:update-python-api": "cd scripts && npm install && npx tsc && ((echo 'let library_arg=null;' && npx esbuild --platform=node --format=esm --loader:.py=text --alias:pysrc=../pysrc --bundle compiled/scripts/process-pyodide-api.js) | node) > ../src/autocompletion/python-api.json",
        "preprocess:build-docs": "cd docs-sphinx && make clean && make html",
        "preprocess:update-test-library-ac": "concurrently \"cross-env LIBRARY='http://localhost:8089/test-library/' npm run library:make-ac-json\" \"npm run test:cypress:serve-assets\"",
        "cy:run:microbit": "npx cypress run --env mode=microbit",
        "cy:run:python": "npx cypress run --env mode=python",
        "test:cypress:serve-assets": "npx serve tests/cypress/test-http-assets/ -l 8089 --cors",
        "test:cypress:serve-both": "concurrently \"npm run serve:python\" \"npm run test:cypress:serve-assets\"",
        "test:cypress:microbit-only": "cross-env WAIT_ON_TIMEOUT=90000 start-server-and-test serve:microbit http-get://localhost:8081/microbit/ cy:run:microbit",
        "test:cypress:python-only": "cross-env WAIT_ON_TIMEOUT=90000 start-server-and-test test:cypress:serve-both http-get://localhost:8081/editor/ cy:run:python",
        "test:cypress": "cross-env WAIT_ON_TIMEOUT=90000 start-server-and-test test:cypress:serve-both http-get://localhost:8081/editor/ cy:run:python && cross-env WAIT_ON_TIMEOUT=90000 start-server-and-test serve:microbit http-get://localhost:8081/microbit/ cy:run:microbit",
        "playwright:run": "npx playwright test",
        "test:playwright": "cross-env BASE_URL=http://localhost:8081/editor/ start-server-and-test serve:python:dist:playwright http-get://localhost:8081/editor/ playwright:run"
    },
    "dependencies": {
        "@azure/msal-browser": "^4.15.0",
        "@fortawesome/free-solid-svg-icons": "^5.15.4",
        "@microbit/microbit-fs": "^0.9.2",
        "@popperjs/core": "^2.11.4",
        "@types/google.accounts": "^0.0.2",
        "@types/google.picker": "^0.0.39",
        "@types/jquery": "^3.5.16",
        "@types/lodash": "^4.14.191",
        "@types/object-hash": "^3.0.6",
        "@types/path-browserify": "^1.0.3",
        "@types/sortablejs": "^1.10.6",
        "@types/splitpanes": "^2.2.6",
        "@vitejs/plugin-vue2": "^2.3.4",
        "@wsfe/ctree": "^2.4.1",
        "audiobuffer-to-wav": "^1.0.0",
        "axios": "^0.30.2",
        "bootstrap": "^4.6.1",
        "bootstrap-vue": "^2.16.0",
        "cheerio": "^1.0.0-rc.5",
        "core-js": "^3.28.0",
        "dapjs": "^2.2.0",
        "detect-collisions": "^9.17.0",
        "file-saver": "^2.0.2",
        "html2canvas": "^1.4.1",
        "jquery": "^3.6.3",
        "js-base64": "^3.7.8",
        "lodash": "^4.17.20",
        "lz-string": "^1.4.4",
        "object-hash": "^3.0.0",
        "pako": "^2.1.0",
        "path-browserify": "^1.0.1",
        "pica": "^9.0.1",
        "pinia": "^2.0.32",
        "pyodide-worker-runner": "^1.4.0",
        "python-shell": "^2.0.3",
        "remove-files-webpack-plugin": "^1.5.0",
        "sortablejs": "^1.15.0",
        "splitpanes": "^2.4.1",
        "sync-message": "^0.0.12",
        "textarea-caret": "^3.1.0",
        "tigerpython-parser": "git+https://github.com/neilccbrown/TigerPython-Parser.git",
        "timed-cache": "^2.0.0",
        "ts-enum-util": "^4.1.0",
        "ts-node": "^10.9.1",
        "ts-node-dev": "^2.0.0",
        "v-blur": "^1.0.4",
        "velocity": "^0.7.3",
        "vite-plugin-conditional-compiler": "^0.4.0",
        "vue": "^2.7.14",
        "vue-advanced-cropper": "^1.11.7",
        "vue-async-computed": "^3.9.0",
        "vue-autosize-input": "^0.1.1",
        "vue-browser-detect-plugin": "^0.1.18",
        "vue-burger-menu": "^2.0.5",
        "vue-context": "^6.0.0",
        "vue-i18n": "^8.27.1",
        "vue-input-autowidth": "^1.0.10",
        "workbox-precaching": "^7.4.0",
        "workbox-routing": "^7.4.0",
        "workbox-strategies": "^7.4.0",
        "zod": "^3.25.32"
    },
    "devDependencies": {
        "@estruyf/github-actions-reporter": "^1.11.0",
        "@microsoft/microsoft-graph-types": "^2.40.0",
        "@pinia/testing": "^0.0.14",
        "@playwright/test": "^1.52.0",
        "@testing-library/cypress": "^10.0.1",
        "@types/audiobuffer-to-wav": "^1.0.4",
        "@types/chai": "^4.2.11",
        "@types/file-saver": "^2.0.5",
        "@types/gapi": "^0.0.47",
        "@types/gapi.client.drive-v3": "^0.0.5",
        "@types/js-yaml": "^4.0.9",
        "@types/lz-string": "^1.3.34",
        "@types/mocha": "^5.2.4",
        "@types/node": "^22.14.0",
        "@types/pako": "^2.0.4",
        "@types/pica": "^9.0.5",
        "@types/pixelmatch": "^5.2.6",
        "@types/pngjs": "^6.0.5",
        "@types/seedrandom": "^3.0.8",
        "@types/testing-library__cypress": "^5.0.13",
        "@types/textarea-caret": "^3.0.0",
        "@types/timed-cache": "^2.0.3",
        "@types/w3c-web-usb": "^1.0.6",
        "@types/webfontloader": "^1.6.38",
        "@typescript-eslint/eslint-plugin": "^8.53.0",
        "@typescript-eslint/parser": "^8.53.0",
        "@vue/eslint-config-standard": "^9.0.1",
        "@vue/test-utils": "^1.3.4",
        "archiver": "^7.0.1",
        "arkit": "^1.6.4",
        "chai": "^4.1.2",
        "chai-sorted": "^0.2.0",
        "concurrently": "^9.1.2",
        "cross-env": "^7.0.3",
        "cross-env-shell": "^7.0.3",
        "cypress": "^13.15.2",
        "cypress-fail-on-console-error": "^5.0.3",
        "cypress-split": "^1.24.18",
        "cypress-terminal-report": "^5.3.9",
        "eslint": "^9.39.2",
        "eslint-plugin-vue": "^10.7.0",
        "husky": "^7.0.4",
        "lint-staged": "^11.2.6",
        "mkdirp": "^3.0.1",
        "mocha": "^10.2.0",
        "mochapack": "^2.1.4",
        "pixelmatch": "^7.1.0",
        "pngjs": "^7.0.0",
        "pyodide": "^0.29.0",
        "rimraf": "^5.0.10",
        "sass": "^1.97.2",
        "seedrandom": "^3.0.5",
        "serve": "^14.2.4",
        "start-server-and-test": "^1.15.4",
        "typescript": "^4.9.5",
        "vite-plugin-checker": "^0.12.0",
        "vite-plugin-static-copy": "^3.1.6",
        "vue-eslint-parser": "^10.2.0",
        "vue-template-compiler": "2.7.14"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "src/**/*.{js,ts,vue}": "eslint --fix"
    },
    "volta": {
        "node": "24.13.0"
    }
}
