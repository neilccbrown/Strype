'''Space Rescue, Version 1.0

Another version of our game, this time with a space theme. Discussed in Chapter 08.

This project is part of the book "Creative programming with Strype".
Authors: Michael Kölling and Neil C.C. Brown
'''
#(=> Section:Imports
from strype.graphics import * 
from strype.sound import * 
from random import randint 
#(=> Section:Definitions
rocket  = Actor(load_image("data:image/png;base64,"),0,-200,"rocket") 
asteroid  = Actor(load_image("data:image/png;base64,"),-200,100) 
score  = 0 
def setup ( ) :
    '''Set up the world. This includes creating the astronauts.'''
    set_background("black") 
    astronaut_image  = load_image("data:image/png;base64,") 
    for count  in range(10)  :
        astronaut  = Actor(astronaut_image,randint(-360,360),randint(-260,260),"astronaut") 
def move_rocket ( ) :
    '''Move the rocket in the game. The rocket reacts to keypresses from the user, and when it finds an astronaut, it will pick them up (remove it from the world).'''
    rocket.move(8) 
    global score 
    if key_pressed("left")  :
        rocket.turn(5) 
    if key_pressed("right")  :
        rocket.turn(-5) 
    if rocket.is_touching("astronaut")  :
        rocket.remove_touching("astronaut") 
        load_sound("data:audio/x-wav;base64,").play() 
        score  = score+20 
        rocket.say_for(str(score),1) 
        if not get_actors("astronaut")  :
            #if there are no astronauts left, land the rocket
            landing() 
def move_asteroid ( ) :
    '''Move the asteroid. The asteroid moves forward automatically. When the asteroid hits the rocket, you lose.'''
    asteroid.move(8) 
    if asteroid.get_x()==-399  :
        asteroid.set_location(400,asteroid.get_y()) 
    elif asteroid.get_x()==400  :
        asteroid.set_location(-399,asteroid.get_y()) 
    elif asteroid.get_y()==-299  :
        asteroid.set_location(asteroid.get_x(),300) 
    elif asteroid.get_y()==300  :
        asteroid.set_location(asteroid.get_x(),-299) 
    if randint(0,99)<10  :
        '''10% chance
        '''
        asteroid.turn(randint(-40,40)) 
    if asteroid.is_touching("rocket")  :
        asteroid.remove_touching("rocket") 
        Actor(load_image("data:image/png;base64,")) 
        load_sound("data:audio/x-wav;base64,").play() 
        stop() 
def landing ( ) :
    '''Final scene: landing the rocket.'''
    global rocket 
    asteroid.remove() 
    Actor(load_image("data:image/png;base64,"),0,-250) 
    rocket.remove() 
    rocket  = Actor(load_image("data:image/png;base64,"),0,300,"rocket") 
    rocket.set_rotation(90) 
    while rocket.get_y()>-170  :
        rocket.move(-3) 
        pace(30) 
    load_sound("data:audio/x-wav;base64,").play() 
    Actor(load_image("data:image/png;base64,")) 
    stop() 
#(=> Section:Main
setup() 
while True  :
    move_rocket() 
    move_asteroid() 
    pace(30) 
#(=> Section:End
