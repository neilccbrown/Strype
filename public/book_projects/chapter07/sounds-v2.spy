'''Sounds, Version 2

This is a project to practice manipulating sounds.

This project is part of the book "Creative Python Programming with Strype".
Authors: Michael Kölling and Neil C.C. Brown
'''
#(=> Section:Imports
from strype.sound import * 
from strype.graphics import * 
#(=> Section:Definitions
def play_backwards (sound ) :
    '''Play the sound backwards'''
    samples  = sound.get_samples() 
    samples.reverse() 
    backwards  = Sound(samples) 
    backwards.play() 
def play_stutter (sound,length,count ) :
    '''Produce the stutter effect'''
    samples  = sound.get_samples() 
    prefix  = samples[:length] 
    total  = prefix*count+samples 
    stutter  = Sound(total) 
    stutter.play() 
#(=> Section:Main
hello  = load_sound("data:audio/wav;base64,") 

while True  :
    keypress  = get_key() 
    if keypress=='2'  :
        play_backwards(hello) 
    if keypress=='3'  :
        play_stutter(hello,9000,7) 

#(=> Section:End
