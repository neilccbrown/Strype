'''text-generation, Version 0.2
In this version of the project, we can create bigrams of our text, and we can generate a sequence of words based on these bigrams.

This project is part of the book "Creative Python Programming with Strype".
Authors: Michael Kölling and Neil C.C. Brown'''
#(=> Section:Imports
import random 
#(=> Section:Definitions
#(=> FrameState:FoldToHeader;Frozen
def read_file (filename ) :
    '''Reads the full content of the file and returns it as a string'''
    with open(filename,encoding="utf-8")  as f  :
        return f.read() 
def make_bigrams (text ) :
    '''Take a text as a parameter and return a list of the bigrams in the text.'''
    words  = text.split() 
    bigrams  = zip(words,words[1:]) 
    return list(bigrams) 
def generate_next_word (prev_word,bigrams ) :
    '''Given a previous word and a list of bigrams, return a next word by randomly selecting one of the matching bigrams.'''
    following  = [] 
    for first,second  in bigrams  :
        if first==prev_word  :
            following.append(second) 
    if len(following)==0  :
        return random.choice(bigrams)[1] 
    else :
        return random.choice(following) 
#(=> Section:Main
#(=> Disabled:text  = "I read the news today, oh, boy. About a lucky man who made the grade." 
text  = read_file("pride-and-prejudice.txt") 
bigrams  = make_bigrams(text) 

word  = "It" 
for n  in range(50)  :
    print(word,end=" ") 
    word  = generate_next_word(word,bigrams) 
#(=> Section:End
