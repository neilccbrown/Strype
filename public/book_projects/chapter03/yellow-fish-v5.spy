'''Yellow Fish, Version 0.5
In this version we can control the fish with our right and left arrow keys, we have shrimp to eat, and a shark swims around and tries to eat us.

This project is part of the book "Creative programming with Strype".
Authors: Michael Kölling and Neil C.C. Brown
'''
#(=> Section:Imports
from strype.graphics import * 
from random import randint 
#(=> Section:Definitions
#(=> Section:Main
set_background("LightBlue") 

fish  = Actor(load_image("data:image/png;base64,"),0,-200,"fish") 
for count  in range(0,15)  :
    shrimp  = Actor(load_image("data:image/png;base64,"),randint(-360,360),randint(-260,260),"shrimp") 
shark  = Actor(load_image("data:image/png;base64,"),-200,100) 

while True  :
    fish.move(8) 
    if key_pressed("left")  :
        fish.turn(5) 
    if key_pressed("right")  :
        fish.turn(-5) 
    if fish.is_touching("shrimp")  :
        fish.remove_touching("shrimp") 
    shark.move(12) 
    if shark.is_at_edge()  :
        shark.turn(15) 
    if shark.is_touching("fish")  :
        shark.remove_touching("fish") 
    pace(30) 
#(=> Section:End
