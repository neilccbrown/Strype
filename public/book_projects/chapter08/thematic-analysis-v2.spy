'''thematic-analysis, Version 0.2
This project is a starting point for a sequence of exercises of analysing the words in a text.
In this version, we can count the frequency of a single word in a text.

This project is part of the book "Creative Python Programming with Strype".
Authors: Michael Kölling and Neil C.C. Brown'''
#(=> Section:Imports
import string 
#(=> Section:Definitions
#(=> FrameState:FoldToHeader;Frozen
def read_file (filename ) :
    '''Read a file from disk and return the content of the file as a single string.
    
    Parameter:   
       filename : str
           The name of the file to be read. The file must exist.
    Returns:
       str: The content of this file as a single string.'''
    with open(filename,encoding="utf-8")  as f  :
        return f.read() 
#(=> FrameState:FoldToHeader;Frozen
def get_expected_frequencies ( ) :
    '''Returns a dictionary with expected frequencies for words in the English language.'''
    result  = {} 
    with open("/strype/book/word_counts.txt","r")  as f  :
        for line  in f  :
            line  = line.strip() 
            if not line  :
                continue
                # skip empty lines
            parts  = line.split() 
            if len(parts)!=2  :
                continue
            key,value_str  = parts 
            try :
                value  = float(value_str) 
            except ValueError  :
                continue
            result[key]  = value 
    return result 
def count_word (search_word,text ) :
    '''Return the number of times the \'search_word\' appears in \'text\'.'''
    text  = text.lower() 
    words  = text.split() 
    count  = 0 
    for word  in words  :
        word  = word.strip(string.punctuation) 
        if search_word==word  :
            count  = count+1 
    return count 
#(=> Section:Main
count  = count_word("say","You say, Yes, I say, No. You say, Stop and I say, Go, go, go") 
print(count) 

text  = read_file("winnie-the-pooh.txt") 
count  = count_word("piglet",text) 
print(count) 
#(=> Section:End
