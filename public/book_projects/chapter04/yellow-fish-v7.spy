'''Yellow Fish, Version 1.0

This is the last version of this project for this book. It is a playable game with some of the improvements suggested at the end of Chapter 03 implemented.

This project is part of the book "Creative programming with Strype".
Authors: Michael Kölling and Neil C.C. Brown
'''
#(=> Section:Imports
from strype.graphics import * 
from strype.sound import * 
from random import randint 
#(=> Section:Definitions
fish  = Actor(load_image("data:image/png;base64,"),0,-200,"fish") 
shark  = Actor(load_image("data:image/png;base64,"),-200,100) 
score  = 0 
def setup ( ) :
    '''Set up the world. This includes creating the shrimp.'''
    set_background("LightBlue") 
    for count  in range(0,15)  :
        shrimp  = Actor(load_image("data:image/png;base64,"),randint(-360,360),randint(-260,260),"shrimp") 
def move_fish ( ) :
    '''Move the fish in the game. The fish reacts to keypresses from the user, and when it encounters a shrimp, it iwll remove it from the world.'''
    fish.move(8) 
    global score 
    if key_pressed("left")  :
        fish.turn(5) 
    if key_pressed("right")  :
        fish.turn(-5) 
    if fish.is_touching("shrimp")  :
        fish.remove_touching("shrimp") 
        load_sound("data:audio/x-wav;base64,").play() 
        score  = score+20 
        fish.say_for(str(score),1) 
        if not get_actors("shrimp")  :
            #if there are no shrimp left...  you win!
            load_sound("data:audio/x-wav;base64,").play() 
            Actor(load_image("data:image/png;base64,")) 
            stop() 
def move_shark ( ) :
    '''Move the shark. The shark moves forward automatically and turns at the edge of the screen. When the shark finds the fish, it will eat it and the game is over.'''
    shark.move(12) 
    if shark.is_at_edge()  :
        shark.turn(15) 
    if randint(0,99)<10  :
        '''10% chance
        '''
        shark.turn(randint(-40,40)) 
    if shark.is_touching("fish")  :
        shark.remove_touching("fish") 
        Actor(load_image("data:image/png;base64,")) 
        load_sound("data:audio/x-wav;base64,").play() 
        stop() 
#(=> Section:Main
setup() 
while True  :
    move_fish() 
    move_shark() 
    pace(30) 
#(=> Section:End
