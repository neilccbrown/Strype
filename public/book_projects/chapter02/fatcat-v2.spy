'''fatcat, Version 0.2

Make the fat cat walk, eat or dance. Anything that is not boring.

This project is part of the book "Creative programming with Strype".
Authors:  Michael Kölling and Neil C.C. Brown'''
#(=> Section:Imports
from strype.graphics import * 
from strype.sound import * 
#(=> Section:Definitions
class Cat(Actor)  :
    '''A cute old cat'''
    #(=> FrameState:FoldToDocumentation
    def __init__ (self,x=0,y=0 ) :
        '''Initialise this cat, ready to play.'''
        self.cat_image  = load_image("data:image/png;base64,") 
        super().__init__(self.cat_image,x,y) 
        self.tired  = False 
        self.hungry  = False 
        self.bored  = True 
    #(=> FrameState:FoldToDocumentation
    def walk (self,distance,direction,img1,img2 ) :
        '''Walk a certain distance, either left or right. This method is not meant to be called directly; it is used by walk_left and walk_right.'''
        for i  in range(distance)  :
            self.set_image(img1) 
            pause(0.4) 
            self.set_location(self.get_x()+direction,self.get_y()) 
            self.set_image(img2) 
            pause(0.4) 
            self.set_location(self.get_x()+direction,self.get_y()) 
        self.set_image(self.cat_image) 
    #(=> FrameState:FoldToDocumentation
    def walk_left (self,distance ) :
        '''Walk left for a given number of steps. Use a small number for the steps.'''
        self.walk(distance,-20,load_image("data:image/png;base64,"),load_image("data:image/png;base64,")) 
    #(=> FrameState:FoldToDocumentation
    def walk_right (self,distance ) :
        '''Walk right for a given number of steps. Use a small number for the steps.'''
        self.walk(distance,20,load_image("data:image/png;base64,"),load_image("data:image/png;base64,")) 
    #(=> FrameState:FoldToDocumentation
    def shout_hooray (self, ) :
        '''It does what it says: Shout "Hooray"'''
        self.say_for("Hooray!",3) 
        hooray  = load_sound("data:audio/x-wav;base64,") 
        hooray.play() 
    #(=> FrameState:FoldToHeader
    def dance (self, ) :
        '''Dance for a little bit.'''
        load_sound("data:audio/x-wav;base64,").___strype_blankplay() 
        dance1  = load_image("data:image/png;base64,") 
        dance2  = load_image("data:image/png;base64,") 
        for i  in range(2)  :
            self.set_image(dance1) 
            pause(0.7) 
            self.set_image(self.cat_image) 
            pause(0.5) 
            self.set_image(dance2) 
            pause(0.5) 
            self.set_image(self.cat_image) 
            pause(0.5) 
        for i  in range(5)  :
            self.set_image(dance1) 
            pause(0.5) 
            self.set_image(dance2) 
            pause(0.4) 
        self.set_image(self.cat_image) 
        self.tired  = True 
        self.hungry  = True 
        self.bored  = False 
    #(=> FrameState:FoldToDocumentation
    def sleep (self,how_long ) :
        '''Sleep for some time. The parameter determines how long. Use a small number.'''
        sleep_img  = [load_image("data:image/png;base64,"),load_image("data:image/png;base64,"),load_image("data:image/png;base64,"),load_image("data:image/png;base64,")] 
        for i  in range(how_long)  :
            for j  in range(4)  :
                self.set_image(sleep_img[j]) 
                pause(0.6) 
        self.set_image(self.cat_image) 
        self.tired  = False 
        self.bored  = True 
    #(=> FrameState:FoldToDocumentation
    def eat (self, ) :
        '''Eat something. It helps with being hungry.'''
        eat1  = load_image("data:image/png;base64,") 
        eat2  = load_image("data:image/png;base64,") 
        for i  in range(4)  :
            self.set_image(eat1) 
            pause(0.7) 
            self.set_image(eat2) 
            pause(0.5) 
        self.set_image(self.cat_image) 
        self.tired  = True 
        self.hungry  = False 
    #(=> FrameState:FoldToDocumentation
    def is_alone (self, ) :
        '''Check whether the cat is alone. Return True if it is, or False if another cat is around.'''
        number_of_cats  = len(get_actors()) 
        return number_of_cats<2 
    #(=> FrameState:FoldToDocumentation
    def has_company (self, ) :
        '''The opposite of \'is_alone()\': Return True if we have company, False otherwise.'''
        return not self.is_alone() 
    #(=> FrameState:FoldToDocumentation
    def is_hungry (self, ) :
        '''Return True if the cat is currently hungry.'''
        return self.hungry 
    #(=> FrameState:FoldToDocumentation
    def is_tired (self, ) :
        '''Return True if the cat is currently tired.'''
        return self.tired 
    #(=> FrameState:FoldToDocumentation
    def is_bored (self, ) :
        '''Return True if the cat is bored.'''
        return self.bored 
#(=> Section:Main
set_background("white") 

cat  = Cat(-100,50) 
cat2  = Cat(200,-100) 
if cat.has_company()  :
    cat.shout_hooray() 
else :
    cat.sleep(3) 
if cat2.has_company()  :
    cat2.dance() 
cat2.walk_left(2) 
cat2.sleep(3) 
#(=> Section:End
