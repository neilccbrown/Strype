'''The crab and the lobster.
This is a simple project to experiment with function calls and method calls.

This project is part of the book "Creative programming with Strype".
Authors: Neil C.C. Brown and Michael Kölling'''
#(=> Section:Imports
from strype.graphics import * 
#(=> Section:Definitions
#(=> Section:Main
set_background("Tan") 
crab  = Actor(load_image("data:image/png;base64,"),-220,0) 
lobster  = Actor(load_image("data:image/png;base64,"),280,0) 

crab.say_for("Knock, knock",2) 
pause(2) 
lobster.say_for("Who's there?",2) 
pause(2) 
crab.say_for("Stopwatch",2) 
pause(2) 
lobster.say_for("Stopwatch who?",2) 
pause(2) 
crab.say_for("Stopwatch you're doing and let me in!",4,30) 
#(=> Section:End
